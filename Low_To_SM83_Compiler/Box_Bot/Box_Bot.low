	HL = SP + 255;		# Makes room on stack for 1 byte
	[HL] = E;		# Writes X to stack
	SP = HL;		# Update stack pointer
	call place_spritechain_in_oam_buffer;		# Calls function
	SP += 5;		# Removes pushed parameters from stack
