		# B = Camera_Y; 0
		# C = Camera_Y; 0
		# D = Condition; 0
		# E = ???; 0
		# H = ???; 0
		# L = ???; 0
	HL = $FF00;
	B = [HL];		# Dereferences address
	# Current tracer registers:
		# A = Flag; 1
		# B = Value_Back; 1
		# C = Camera_Y; 0
		# D = Condition; 0
		# E = ???; 0
		# H = ???; 0
		# L = ???; 0
	HL = $FF00;
	C = [HL];		# Dereferences address
	# Current tracer registers:
		# A = Flag; 1
		# B = ???; 0
		# C = Value_Back; 1
		# D = Condition; 0
		# E = ???; 0
		# H = ???; 0
		# L = ???; 0
	HL = $FF00;
	B = [HL];		# Dereferences address
	# Current tracer registers:
		# A = Flag; 1
		# B = Value_Back; 1
		# C = ???; 0
		# D = Condition; 0
		# E = ???; 0
		# H = ???; 0
		# L = ???; 0
	C = A;		# Moves Flag into other register
	A = B;		# creates copy of Value_Back register
	SP += 1;		# Remove local variables from stack
	return;
}

