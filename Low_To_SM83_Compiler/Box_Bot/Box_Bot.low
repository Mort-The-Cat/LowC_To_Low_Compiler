subroutine Set_Interrupt_Function
{
	# Current tracer registers:
		# A = ???; 0
		# B = ???; 0
		# C = ???; 0
		# D = ???; 0
		# E = ???; 0
		# H = ???; 0
		# L = ???; 0
	HL = SP + 2;		# Fetches Function_Pointer off the stack
	A = [HL];		# Store lower byte temporarily
	HL++;
	H = [HL];		# Store upper byte
	L = A;		# Move lower byte from temp register
	B = H;		# Moves @statement_value@ into upper register
	C = L;		# Moves into lower register
	HL = SP + 4;		# Fetches Address off the stack
	A = [HL];		# Store lower byte temporarily
	HL++;
	H = [HL];		# Store upper byte
	L = A;		# Move lower byte from temp register
	[HL] = C; 		# Stores value into memory location
	# Current tracer registers:
		# A = ???; 0
		# B = Function_Pointer; 1
		# C = Function_Pointer; 1
		# D = ???; 0
		# E = ???; 0
		# H = ???; 0
		# L = ???; 0
	HL = SP + 4;		# Fetches Address off the stack
	A = [HL];		# Store lower byte temporarily
	HL++;
	H = [HL];		# Store upper byte
	L = A;		# Move lower byte from temp register
	HL++;		# Increments Address
	# Current tracer registers:
		# A = ???; 0
		# B = Function_Pointer; 1
		# C = Function_Pointer; 1
		# D = ???; 0
		# E = ???; 0
		# H = Address; 1
		# L = Address; 1
	D = H;		# Makes 'H' a copy of Address
	E = L;		# Makes 'L' a copy of Address
	[HL] = B; 		# Stores value into memory location
	# Current tracer registers:
		# A = ???; 0
		# B = Function_Pointer; 1
		# C = Function_Pointer; 1
		# D = Address; 1
		# E = Address; 1
		# H = ???; 0
		# L = ???; 0
	return;
}

subroutine State_Function
{
	# Current tracer registers:
		# A = ???; 0
		# B = Function_Pointer; 0
		# C = Function_Pointer; 0
		# D = Address; 0
		# E = Address; 0
		# H = ???; 0
		# L = ???; 0
	SP += 255;		# byte Inputs;
	# Current tracer registers:
		# A = ???; 0
		# B = Function_Pointer; 0
		# C = Function_Pointer; 0
		# D = Address; 0
		# E = Address; 0
		# H = ???; 0
		# L = ???; 0
	A = $E0;
	HL = SP + 255;		# Makes room on stack for 1 byte
	[HL] = A;		# Writes Flag to stack
	SP = HL;		# Update stack pointer
	call Get_Controller_Inputs;		# Calls function
	SP += 1;		# Removes pushed parameters from stack
	# Current tracer registers:
		# A = Inputs; 1
		# B = Function_Pointer; 0
		# C = Function_Pointer; 0
		# D = Address; 0
		# E = Address; 0
		# H = ???; 0
		# L = ???; 0
	SP += 255;		# byte Condition;
	# Current tracer registers:
		# A = Inputs; 1
		# B = Function_Pointer; 0
		# C = Function_Pointer; 0
		# D = Address; 0
		# E = Address; 0
		# H = ???; 0
		# L = ???; 0
	SP += 254;		# byte* State_Pointer;
	# Current tracer registers:
		# A = Inputs; 1
		# B = Function_Pointer; 0
		# C = Function_Pointer; 0
		# D = Address; 0
		# E = Address; 0
		# H = ???; 0
		# L = ???; 0
	BC = $04;
	HL = SP + 6;		# Fetches Player_Data off the stack
	D = [HL];		# Store lower byte temporarily
	HL++;
	H = [HL];		# Store upper byte
	L = D;		# Move lower byte from temp register
	HL += BC;		# S_PLUS16
	# Current tracer registers:
		# A = Inputs; 1
		# B = ???; 0
		# C = ???; 0
		# D = ???; 0
		# E = Address; 0
		# H = State_Pointer; 1
		# L = State_Pointer; 1
	B = [HL];		# Dereferences address
	# Current tracer registers:
		# A = Inputs; 1
		# B = Condition; 1
		# C = ???; 0
		# D = ???; 0
		# E = Address; 0
		# H = State_Pointer; 1
		# L = State_Pointer; 1

	A.$01;		# Gets conditional
	jump not_zero __if_statement__0;		# If statement jump
	# Current tracer registers:
		# A = Inputs; 1
		# B = Condition; 1
		# C = ???; 0
		# D = ???; 0
		# E = Address; 0
		# H = State_Pointer; 1
		# L = State_Pointer; 1
	DE = 4;
	push HL;		# This frees up the HL register to access the stack with
	HL = SP + 5;		# Memory location of Inputs
	[HL] = A;		# Stores Inputs back into memory
	HL = SP + 4;		# Memory location of Condition
	[HL] = B;		# Stores Condition back into memory
	pop HL;		# This gets back the HL register value before forced store
	B = H;		# Makes 'H' a copy of State_Pointer
	C = L;		# Makes 'L' a copy of State_Pointer
	HL += DE;		# S_PLUS16
	[HL] = 0; 		# Stores value into memory location
	# Current tracer registers:
		# A = Inputs; 0
		# B = State_Pointer; 1
		# C = State_Pointer; 1
		# D = ???; 0
		# E = ???; 0
		# H = ???; 0
		# L = ???; 0

	HL = SP + 2;		# Fetches Condition off the stack
	A = [HL];		# Store value into 'A' register
	A -= 1;		# S_MINUS8
	A |= A;		# This just gets the CPU flags
	jump not_zero __if_statement__1;		# If statement jump
	# Current tracer registers:
		# A = ???; 0
		# B = State_Pointer; 1
		# C = State_Pointer; 1
		# D = ???; 0
		# E = ???; 0
		# H = @@stack_pointer@@; 0
		# L = @@stack_pointer@@; 0
	H = B;		# Creates copy of State_Pointer
	L = C;		# Creates copy of State_Pointer
	[HL] = 5; 		# Stores value into memory location
	# Current tracer registers:
		# A = ???; 0
		# B = State_Pointer; 1
		# C = State_Pointer; 1
		# D = ???; 0
		# E = ???; 0
		# H = ???; 0
		# L = ???; 0
	# Register snapshot:
		# B = State_Pointer; 1
	label __if_statement__1;		# If statement label

	# Current tracer registers:
		# A = ???; 0
		# B = State_Pointer; 1
		# C = State_Pointer; 1
		# D = ???; 0
		# E = ???; 0
		# H = ???; 0
		# L = ???; 0
	H = B;		# Creates copy of State_Pointer
	L = C;		# Creates copy of State_Pointer
	[HL]--;		# Decrements address
	# Current tracer registers:
		# A = ???; 0
		# B = State_Pointer; 1
		# C = State_Pointer; 1
		# D = ???; 0
		# E = ???; 0
		# H = ???; 0
		# L = ???; 0
	SP += 4;		# Remove local variables from stack
	return;
	# Current tracer registers:
		# A = ???; 0
		# B = State_Pointer; 1
		# C = State_Pointer; 1
		# D = ???; 0
		# E = ???; 0
