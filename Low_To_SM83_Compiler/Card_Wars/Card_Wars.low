		# H = ???; 0
		# L = ???; 0
	BC = $FF00;
	# Current tracer registers:
		# A = Scanline; 0
		# B = Controller_Reg; 1
		# C = Controller_Reg; 1
		# D = Address; 0
		# E = Address; 0
