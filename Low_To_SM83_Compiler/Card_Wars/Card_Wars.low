		# A = ???; 0
		# B = ???; 0
		# C = ???; 0
		# D = ???; 0
		# E = ???; 0
		# H = Address; 1
		# L = Address; 1
	B = $00;		# Zeros upper byte
	C = [HL];		# Dereferences address
	# Current tracer registers:
		# A = ???; 0
		# B = Address; 1
		# C = Address; 1
		# D = ???; 0
		# E = ???; 0
		# H = ???; 0
		# L = ???; 0
	D = B;		# Makes 'H' a copy of Address
	E = C;		# Makes 'L' a copy of Address
	C <<= 1;
	B <<>|= 1;
	C <<= 1;
	B <<>|= 1;
	C <<= 1;
	B <<>|= 1;
	C <<= 1;
	B <<>|= 1;
	# Current tracer registers:
		# A = ???; 0
		# B = Address; 1
		# C = Address; 1
		# D = ???; 0
		# E = ???; 0
		# H = ???; 0
		# L = ???; 0
	DE = $8800;
	H = B;		# Creates copy of Address
	L = C;		# Creates copy of Address
	HL += DE;		# S_PLUS16
	# Current tracer registers:
		# A = ???; 0
		# B = ???; 0
		# C = ???; 0
		# D = ???; 0
		# E = ???; 0
		# H = Address; 1
		# L = Address; 1
	B = H;		# Makes 'H' a copy of Address
	C = L;		# Makes 'L' a copy of Address
	SP += 2;		# Remove local variables from stack
	return;
}

