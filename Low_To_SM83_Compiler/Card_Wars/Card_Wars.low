		# C = Controller_Reg; 1
		# D = Address; 0
		# E = Address; 0
		# H = ???; 0
		# L = ???; 0
	H = B;		# Creates copy of Controller_Reg
	L = C;		# Creates copy of Controller_Reg
	D = [HL];		# Dereferences address
	# Current tracer registers:
		# A = Flag; 1
		# B = Controller_Reg; 1
		# C = Controller_Reg; 1
		# D = Value_Back; 1
		# E = Address; 0
		# H = ???; 0
		# L = ???; 0
	H = B;		# Creates copy of Controller_Reg
	L = C;		# Creates copy of Controller_Reg
	E = [HL];		# Dereferences address
	# Current tracer registers:
		# A = Flag; 1
		# B = Controller_Reg; 1
		# C = Controller_Reg; 1
		# D = ???; 0
		# E = Value_Back; 1
		# H = ???; 0
		# L = ???; 0
	H = B;		# Creates copy of Controller_Reg
	L = C;		# Creates copy of Controller_Reg
	D = [HL];		# Dereferences address
	# Current tracer registers:
		# A = Flag; 1
		# B = Controller_Reg; 1
		# C = Controller_Reg; 1
		# D = Value_Back; 1
		# E = ???; 0
		# H = ???; 0
		# L = ???; 0
	E = A;		# Moves Flag into other register
	A = D;		# creates copy of Value_Back register
	SP += 3;		# Remove local variables from stack
	return;
}

