	L = [HL];		# Stores Position into lower byte of HL
	H = $00;		# Zeroes out upper byte
	# Current tracer registers:
		# A = Player_Input; 0
		# B = ???; 0
		# C = ???; 0
		# D = Value_Back; 0
		# E = Flag; 0
		# H = Address; 1
		# L = Address; 1
	B = H;		# Makes 'H' a copy of Address
	C = L;		# Makes 'L' a copy of Address
	D = H;		# Moves Address into upper register
	E = L;		# Moves into lower register
	HL = SP + 5;		# Fetches Destinations off the stack
	A = [HL];		# Store lower byte temporarily
	HL++;
	H = [HL];		# Store upper byte
	L = A;		# Move lower byte from temp register
	HL += BC;		# S_PLUS16
