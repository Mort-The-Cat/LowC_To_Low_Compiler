subroutine Set_Interrupt_Function
{
	# Current tracer registers:
		# A = ???; 0
		# B = ???; 0
		# C = ???; 0
		# D = ???; 0
		# E = ???; 0
		# H = ???; 0
		# L = ???; 0
	HL = SP + 2;		# Fetches Function_Pointer off the stack
	A = [HL];		# Store lower byte temporarily
	HL++;
	H = [HL];		# Store upper byte
	L = A;		# Move lower byte from temp register
	B = H;		# Moves @statement_value@ into upper register
	C = L;		# Moves into lower register
	HL = SP + 4;		# Fetches Address off the stack
	A = [HL];		# Store lower byte temporarily
	HL++;
	H = [HL];		# Store upper byte
	L = A;		# Move lower byte from temp register
	[HL] = C; 		# Stores value into memory location
	# Current tracer registers:
		# A = ???; 0
		# B = Function_Pointer; 1
		# C = Function_Pointer; 1
		# D = ???; 0
		# E = ???; 0
		# H = ???; 0
		# L = ???; 0
	HL = SP + 4;		# Fetches Address off the stack
	A = [HL];		# Store lower byte temporarily
	HL++;
	H = [HL];		# Store upper byte
	L = A;		# Move lower byte from temp register
	HL++;		# Increments Address
	# Current tracer registers:
		# A = ???; 0
		# B = Function_Pointer; 1
		# C = Function_Pointer; 1
		# D = ???; 0
		# E = ???; 0
		# H = Address; 1
		# L = Address; 1
	D = H;		# Makes 'H' a copy of Address
	E = L;		# Makes 'L' a copy of Address
	[HL] = B; 		# Stores value into memory location
	# Current tracer registers:
		# A = ???; 0
		# B = Function_Pointer; 1
		# C = Function_Pointer; 1
		# D = Address; 1
		# E = Address; 1
		# H = ???; 0
		# L = ???; 0
	return;
}

subroutine Wait_For_VBlank
{
	# Current tracer registers:
		# A = ???; 0
		# B = Function_Pointer; 0
		# C = Function_Pointer; 0
		# D = Address; 0
		# E = Address; 0
		# H = ???; 0
		# L = ???; 0
	SP += 255;		# byte Scanline;
	# Current tracer registers:
		# A = ???; 0
		# B = Function_Pointer; 0
		# C = Function_Pointer; 0
		# D = Address; 0
		# E = Address; 0
		# H = ???; 0
		# L = ???; 0

	label __do_while_statement__0;		# do/while loop label
	# Current tracer registers:
		# A = ???; 0
		# B = Function_Pointer; 0
		# C = Function_Pointer; 0
		# D = Address; 0
		# E = Address; 0
		# H = ???; 0
		# L = ???; 0
	HL = $FF44;
	A = [HL];		# Dereferences address
	A < $90;		# S_LESS_THAN8
	jump  not_carry __do_while_statement__0_memory_cleanup;		# do/while memory-cleanup loop jump
	# Current tracer registers:
		# A = Scanline; 1
		# B = Function_Pointer; 0
		# C = Function_Pointer; 0
		# D = Address; 0
		# E = Address; 0
		# H = ???; 0
		# L = ???; 0
	# Register snapshot:
	HL = SP + 0;		# Memory location of Scanline
	[HL] = A;		# Stores Scanline back into memory
	jump __do_while_statement__0;		# do/while loop jump
	label __do_while_statement__0_memory_cleanup;
	# Current tracer registers:
		# A = Scanline; 1
		# B = Function_Pointer; 0
		# C = Function_Pointer; 0
		# D = Address; 0
		# E = Address; 0
		# H = ???; 0
		# L = ???; 0
	# Register snapshot:
	HL = SP + 0;		# Memory location of Scanline
	[HL] = A;		# Stores Scanline back into memory


	# Current tracer registers:
		# A = Scanline; 0
		# B = Function_Pointer; 0
		# C = Function_Pointer; 0
		# D = Address; 0
		# E = Address; 0
		# H = ???; 0
		# L = ???; 0
	SP += 1;		# Remove local variables from stack
	return;
}

subroutine Get_Controller_Input
{
	# Current tracer registers:
		# A = Scanline; 0
		# B = Function_Pointer; 0
		# C = Function_Pointer; 0
		# D = Address; 0
		# E = Address; 0
		# H = ???; 0
		# L = ???; 0
	SP += 255;		# byte Value_Back;
	# Current tracer registers:
		# A = Scanline; 0
		# B = Function_Pointer; 0
		# C = Function_Pointer; 0
		# D = Address; 0
		# E = Address; 0
		# H = ???; 0
		# L = ???; 0
	SP += 254;		# byte* Controller_Reg;
	# Current tracer registers:
		# A = Scanline; 0
		# B = Function_Pointer; 0
		# C = Function_Pointer; 0
		# D = Address; 0
		# E = Address; 0
		# H = ???; 0
		# L = ???; 0
	BC = $FF00;
	# Current tracer registers:
		# A = Scanline; 0
		# B = Controller_Reg; 1
		# C = Controller_Reg; 1
		# D = Address; 0
		# E = Address; 0
		# H = ???; 0
		# L = ???; 0
	HL = SP + 5;		# Fetches Flag off the stack
	A = [HL];		# Stores Flag into A register
	H = B;		# Creates copy of Controller_Reg
	L = C;		# Creates copy of Controller_Reg
	[HL] = A; 		# Stores value into memory location
	# Current tracer registers:
		# A = Flag; 1
		# B = Controller_Reg; 1
		# C = Controller_Reg; 1
		# D = Address; 0
		# E = Address; 0
		# H = ???; 0
		# L = ???; 0
	H = B;		# Creates copy of Controller_Reg
	L = C;		# Creates copy of Controller_Reg
	D = [HL];		# Dereferences address
	# Current tracer registers:
		# A = Flag; 1
		# B = Controller_Reg; 1
		# C = Controller_Reg; 1
		# D = Value_Back; 1
		# E = Address; 0
		# H = ???; 0
		# L = ???; 0
	H = B;		# Creates copy of Controller_Reg
	L = C;		# Creates copy of Controller_Reg
	E = [HL];		# Dereferences address
	# Current tracer registers:
		# A = Flag; 1
		# B = Controller_Reg; 1
		# C = Controller_Reg; 1
		# D = ???; 0
		# E = Value_Back; 1
		# H = ???; 0
		# L = ???; 0
	H = B;		# Creates copy of Controller_Reg
	L = C;		# Creates copy of Controller_Reg
	D = [HL];		# Dereferences address
	# Current tracer registers:
		# A = Flag; 1
		# B = Controller_Reg; 1
		# C = Controller_Reg; 1
		# D = Value_Back; 1
		# E = ???; 0
		# H = ???; 0
		# L = ???; 0
	E = A;		# Moves Flag into other register
	A = D;		# creates copy of Value_Back register
	SP += 3;		# Remove local variables from stack
	return;
}

subroutine Test_Scroll_Loop
{
	# Current tracer registers:
		# A = ???; 0
		# B = Controller_Reg; 0
		# C = Controller_Reg; 0
		# D = ???; 0
		# E = Flag; 0
		# H = ???; 0
		# L = ???; 0
	SP += 255;		# byte Player_Input;
	# Current tracer registers:
		# A = ???; 0
		# B = Controller_Reg; 0
		# C = Controller_Reg; 0
		# D = ???; 0
		# E = Flag; 0
		# H = ???; 0
		# L = ???; 0
	HL = $FF90;
	[HL] = 186; 		# Stores value into memory location
	# Current tracer registers:
		# A = ???; 0
		# B = Controller_Reg; 0
		# C = Controller_Reg; 0
		# D = ???; 0
		# E = Flag; 0
		# H = ???; 0
		# L = ???; 0
	HL = $FF91;
	[HL] = 226; 		# Stores value into memory location
	# Current tracer registers:
		# A = ???; 0
		# B = Controller_Reg; 0
		# C = Controller_Reg; 0
		# D = ???; 0
		# E = Flag; 0
		# H = ???; 0
		# L = ???; 0
	HL = $FF92;
	[HL] = 40; 		# Stores value into memory location
	# Current tracer registers:
		# A = ???; 0
		# B = Controller_Reg; 0
		# C = Controller_Reg; 0
		# D = ???; 0
		# E = Flag; 0
		# H = ???; 0
		# L = ???; 0
	HL = $FF93;
	[HL] = 40; 		# Stores value into memory location
	# Current tracer registers:
		# A = ???; 0
		# B = Controller_Reg; 0
		# C = Controller_Reg; 0
		# D = ???; 0
		# E = Flag; 0
		# H = ???; 0
		# L = ???; 0

	label __do_while_statement__1;		# do/while loop label
	# Current tracer registers:
		# A = ???; 0
		# B = Controller_Reg; 0
		# C = Controller_Reg; 0
		# D = ???; 0
		# E = Flag; 0
		# H = ???; 0
		# L = ???; 0
	call Wait_For_VBlank;		# Calls function
	# Current tracer registers:
		# A = ???; 0
		# B = Controller_Reg; 0
		# C = Controller_Reg; 0
		# D = ???; 0
		# E = Flag; 0
		# H = ???; 0
		# L = ???; 0
	HL = $FF42;
	[HL] = 226; 		# Stores value into memory location
	# Current tracer registers:
		# A = ???; 0
		# B = Controller_Reg; 0
		# C = Controller_Reg; 0
		# D = ???; 0
		# E = Flag; 0
		# H = ???; 0
		# L = ???; 0
	HL = $FF93;
	[HL] = 40; 		# Stores value into memory location
	# Current tracer registers:
		# A = ???; 0
		# B = Controller_Reg; 0
		# C = Controller_Reg; 0
		# D = ???; 0
		# E = Flag; 0
		# H = ???; 0
		# L = ???; 0
	HL = $FF90;
	[HL]++;		# Increments address
	# Current tracer registers:
		# A = ???; 0
		# B = Controller_Reg; 0
		# C = Controller_Reg; 0
		# D = ???; 0
		# E = Flag; 0
		# H = ???; 0
		# L = ???; 0
	HL = $FF90;
	A = [HL];		# Dereferences address
	A >>>= 1;
	HL = $FF91;
	[HL] = A; 		# Stores value into memory location
	# Current tracer registers:
		# A = ???; 0
		# B = Controller_Reg; 0
		# C = Controller_Reg; 0
		# D = ???; 0
		# E = Flag; 0
		# H = ???; 0
		# L = ???; 0
	HL = $FF91;
	A = [HL];		# Dereferences address
	B = H;		# Moves  into upper register
	C = L;		# Moves into lower register
	HL = $FF90;
	D = A;		# Moves @value@ into other register
	A = [HL];		# Dereferences address
	A -= D;		# S_MINUS8
	HL = $FF92;
	[HL] = A; 		# Stores value into memory location
	# Current tracer registers:
		# A = ???; 0
		# B = ???; 0
		# C = ???; 0
		# D = ???; 0
		# E = Flag; 0
		# H = ???; 0
		# L = ???; 0
	HL = $FF91;
	A = [HL];		# Dereferences address
	HL = $FF43;
	[HL] = A; 		# Stores value into memory location
	# Current tracer registers:
		# A = ???; 0
		# B = ???; 0
		# C = ???; 0
		# D = ???; 0
		# E = Flag; 0
		# H = ???; 0
		# L = ???; 0
	A = $D0;
	HL = SP + 255;		# Makes room on stack for 1 byte
	[HL] = A;		# Writes Flag to stack
	SP = HL;		# Update stack pointer
	call Get_Controller_Input;		# Calls function
	SP += 1;		# Removes pushed parameters from stack
	A.3;		# Gets conditional
	jump  zero __do_while_statement__1_memory_cleanup;		# do/while memory-cleanup loop jump
	# Current tracer registers:
		# A = Player_Input; 1
		# B = ???; 0
		# C = ???; 0
		# D = ???; 0
		# E = Flag; 0
		# H = ???; 0
		# L = ???; 0
	# Register snapshot:
	HL = SP + 0;		# Memory location of Player_Input
	[HL] = A;		# Stores Player_Input back into memory
	jump __do_while_statement__1;		# do/while loop jump
	label __do_while_statement__1_memory_cleanup;
	# Current tracer registers:
		# A = Player_Input; 1
		# B = ???; 0
		# C = ???; 0
		# D = ???; 0
		# E = Flag; 0
		# H = ???; 0
		# L = ???; 0
	# Register snapshot:
	HL = SP + 0;		# Memory location of Player_Input
	[HL] = A;		# Stores Player_Input back into memory


	# Current tracer registers:
		# A = Player_Input; 0
		# B = ???; 0
		# C = ???; 0
		# D = ???; 0
		# E = Flag; 0
		# H = ???; 0
		# L = ???; 0
	SP += 1;		# Remove local variables from stack
	return;
}

